# Server Configuration
PORT=5000
NODE_ENV=production

# Security Keys
JWT_SECRET=your_jwt_signing_secret_here

# Supabase Credentials
# IMPORTANT: Use the SERVICE_ROLE key (not anon key) for backend operations
# Find it in: Supabase Dashboard > Settings > API > service_role (secret)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# CORS Origins
FRONTEND_URL=https://your-user-app.vercel.app
ADMIN_PANEL_URL=https://your-admin-panel.vercel.app

